# Ignore files generated by the scripts
/.codex/
/.claude/
/.kiro/
/.github/
/.agents/

# Keep committed automation and distributable outputs
!/.github/
/.github/*
!/.github/workflows/
!/.github/workflows/**
!/prebuilt-files/
!/prebuilt-files/**

# Ignore IDE junk
/.idea/
/.vscode/
/__pycache__/

# Ignore downloaded doc files
/ignore/
