# Ignore files generated by the scripts
/.codex/
/.claude/
/.kiro/
/.github/
/.agents/
/.kiropen/

# Keep committed automation and distributable outputs
!/.agents/
/.agents/*
!/.agents/skills/
/.agents/skills/*
!/.agents/skills/add-harness-support/
!/.agents/skills/add-harness-support/**
!/.github/
/.github/*
!/.github/workflows/
!/.github/workflows/**

# Ignore IDE junk
/.idea/
/.vscode/
__pycache__/

# Ignore downloaded doc files
/ignore/
